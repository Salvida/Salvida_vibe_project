SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
CORS_ORIGINS=http://localhost:3000
DEBUG=true

# ── Email notifications (Resend) ──────────────────────────────────────────
# Sign up at https://resend.com and create an API key.
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=Salvida <notifications@yourdomain.com>

# ── Web Push notifications (VAPID) ────────────────────────────────────────
# Generate keys: https://vapidkeys.com  or
#   python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print('private:', v.private_key.decode()); print('public:', v.public_key.decode())"
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_SUBJECT=mailto:admin@yourdomain.com
